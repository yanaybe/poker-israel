# =============================================================================
# DATABASE
# =============================================================================

# Development: SQLite (local file)
DATABASE_URL="file:./dev.db"

# Production: PostgreSQL (replace with real connection string)
# DATABASE_URL="postgresql://user:password@host:5432/poker_israel?schema=public"

# =============================================================================
# NEXTAUTH — REQUIRED
# =============================================================================

# Must be at least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="replace-with-32-char-random-string-in-production"

# Full URL of your deployment (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# PAYPLUS (Israeli payment processor) — REQUIRED for payments
# =============================================================================

# Get from PayPlus merchant dashboard
PAYPLUS_API_KEY=""
PAYPLUS_SECRET_KEY=""
PAYPLUS_PAGE_UID=""

# Set to "true" ONLY in isolated local development to skip webhook signature
# verification. NEVER set this in production or staging.
# PAYPLUS_SKIP_SIG_VERIFY="true"

# =============================================================================
# APP
# =============================================================================

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# SEED — development only
# =============================================================================

# Required when running `npm run db:seed`. Use a strong random password.
# SEED_PASSWORD="replace-with-strong-dev-password"

# =============================================================================
# OPTIONAL INTEGRATIONS (add as you implement each feature)
# =============================================================================

# Sentry — error tracking
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""

# Upstash Redis — rate limiting and caching
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Resend — transactional email (password reset, notifications)
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@yourapp.com"

# Cloudinary — image storage (replaces base64-in-DB)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# PostHog — analytics
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
