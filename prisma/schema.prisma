generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String
  age              Int?
  city             String?
  skillLevel       String    @default("BEGINNER")
  image            String?
  canHostUntil     DateTime?
  // Trust & safety
  isBanned         Boolean   @default(false)
  banReason        String?
  bannedAt         DateTime?
  isAdmin          Boolean   @default(false)
  // Session security
  tokenVersion     Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  gamesHosted           Game[]         @relation("GameHost")
  gameRequests          GameRequest[]
  sentMessages          Message[]      @relation("SentMessages")
  receivedMessages      Message[]      @relation("ReceivedMessages")
  notifications         Notification[]
  strikes               Strike[]
  hostRatingsGiven      HostRating[]   @relation("HostRatingsGiven")
  hostRatingsReceived   HostRating[]   @relation("HostRatingsReceived")
  playerRatingsGiven    PlayerRating[] @relation("PlayerRatingsGiven")
  playerRatingsReceived PlayerRating[] @relation("PlayerRatingsReceived")
  subscription          Subscription?
  lfgPosts              LfgPost[]
  reportsMade           Report[]       @relation("ReportsMade")
  reportsReceived       Report[]       @relation("ReportsReceived")
  passwordResets        PasswordReset[]
}

model Strike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Game {
  id               String   @id @default(cuid())
  hostId           String
  host             User     @relation("GameHost", fields: [hostId], references: [id], onDelete: Cascade)
  title            String
  neighborhood     String?
  location         String
  city             String
  dateTime         DateTime
  buyIn            Int
  gameType         String
  stakes           String
  houseFeeType     String?
  houseFee         Int?
  houseFeePct      Float?
  houseFeeMax      Int?
  maxPlayers       Int
  currentPlayers   Int      @default(1)
  notes            String?
  status           String   @default("OPEN")
  stackMin         Int?
  stackMax         Int?
  rebuyType        String?
  rebuyCap         Int?
  gamePace         String?
  vibeTags         String?
  expectedDuration Float?
  hasFood          Boolean  @default(false)
  hasDrinks        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([city, status, dateTime])
  @@index([gameType])
  @@index([hostId])
  @@index([status, dateTime])

  requests      GameRequest[]
  hostRatings   HostRating[]
  playerRatings PlayerRating[]
  boost         GameBoost?
  reports       Report[]
}

model GameRequest {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("PENDING")
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameId, userId])
  @@index([userId])
  @@index([gameId, status])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([senderId, receiverId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  gameId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, read])
}

// Player rates the host after a game
model HostRating {
  id               String   @id @default(cuid())
  gameId           String
  game             Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  raterId          String
  rater            User     @relation("HostRatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  hostId           String
  host             User     @relation("HostRatingsReceived", fields: [hostId], references: [id], onDelete: Cascade)
  punctuality      Int?
  locationAccuracy Int?
  fairDealing      Int?
  safety           Int?
  comment          String?
  declined         Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@unique([gameId, raterId])
}

// Host rates each player after a game
model PlayerRating {
  id          String   @id @default(cuid())
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  raterId     String
  rater       User     @relation("PlayerRatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  playerId    String
  player      User     @relation("PlayerRatingsReceived", fields: [playerId], references: [id], onDelete: Cascade)
  behavior    Int?
  punctuality Int?
  payment     Int?
  comment     String?
  declined    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([gameId, playerId])
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payplusToken     String   @unique
  status           String   // active | canceled
  currentPeriodEnd DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GameBoost {
  id                    String   @id @default(cuid())
  gameId                String   @unique
  game                  Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  hostId                String
  payplusTransactionUid String   @unique
  boostedUntil          DateTime
  amount                Int
  createdAt             DateTime @default(now())
}

model LfgPost {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city          String
  availableText String
  buyIn         Int?
  gameTypes     String?  // comma-separated: "CASH,TOURNAMENT"
  notes         String?
  status        String   @default("ACTIVE") // ACTIVE | CLOSED
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([city, status, expiresAt])
  @@index([userId, status])
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  location    String
  city        String
  date        DateTime
  website     String?
  description String?
  prizePool   String?
  buyIn       Int?
  createdAt   DateTime @default(now())
}

// User-submitted reports against other users or games
model Report {
  id           String   @id @default(cuid())
  reporterId   String
  reporter     User     @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUserId String?
  targetUser   User?    @relation("ReportsReceived", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetGameId String?
  targetGame   Game?    @relation(fields: [targetGameId], references: [id], onDelete: SetNull)
  reason       String   // SPAM | FAKE_GAME | HARASSMENT | INAPPROPRIATE | SCAM | OTHER
  details      String?
  status       String   @default("PENDING") // PENDING | REVIEWED | ACTIONED | DISMISSED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, createdAt])
  @@index([reporterId])
  @@index([targetUserId])
}

// Password reset tokens — time-limited, single-use
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

// Webhook idempotency log — prevents double-processing PayPlus events
model WebhookEvent {
  id               String   @id @default(cuid())
  transactionUid   String   @unique
  payload          String   // raw JSON stored for audit/replay
  processedAt      DateTime @default(now())

  @@index([transactionUid])
}
